{
  "name": "@fab-orbita/shield",
  "version": "1.1.0",
  "description": "Advanced security framework for Node.js with AI-powered protection",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugins/*": {
      "import": "./dist/plugins/*.mjs",
      "require": "./dist/plugins/*.js",
      "types": "./dist/plugins/*.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "npm run build:clean && npm run build:cjs && npm run build:esm && npm run build:types",
    "build:clean": "rimraf dist",
    "build:cjs": "tsc -p tsconfig.build.json",
    "build:esm": "tsc -p tsconfig.module.json",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "build:analyze": "npm run build && source-map-explorer dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist coverage node_modules",
    "prepublishOnly": "npm run build && npm run test",
    "dev": "ts-node examples/server.ts",
    "start": "node dist/index.js",
    "example": "ts-node examples/server.ts",
    "example:basic": "ts-node examples/basic.ts",
    "example:express": "ts-node examples/express.ts"
  },
  "peerDependencies": {
    "express": "^4.18.2 || ^5.0.0",
    "fastify": "^4.0.0",
    "koa": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "koa": {
      "optional": true
    }
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/events": "^3.0.3",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.19.43",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "express": "^5.2.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "source-map-explorer": "^2.5.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "security",
    "headers",
    "csp",
    "ai",
    "protection",
    "express",
    "fastify",
    "koa",
    "middleware",
    "waf",
    "firewall",
    "xss",
    "csrf",
    "hsts",
    "csp",
    "fab",
    "shield",
    "fab-orbita"
  ],
  "author": {
    "name": "Фабрициус Владимир Николаевич",
    "email": "derector@devorbit.ru"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fab-orbita/shield.git"
  },
  "bugs": {
    "url": "https://github.com/fab-orbita/shield/issues"
  },
  "homepage": "https://fab.devorbit.ru",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
