{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "types": ["node", "jest"],
    "isolatedModules": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["tests/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist", "examples/**/*"]
}